# ==========================================
# APPLICATION
# ==========================================

NODE_ENV=development

APP_NAME=ROMI TRADERS

APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:3000/api


# ==========================================
# DATABASE
# ==========================================

DATABASE_URL="postgresql://postgres:password@localhost:5432/romi_traders"


# ==========================================
# AUTHENTICATION
# ==========================================

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY

JWT_EXPIRES_IN=7d

NEXTAUTH_URL=http://localhost:3000

NEXTAUTH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET


# ==========================================
# EMAIL SMTP
# ==========================================

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USER=your-email@gmail.com

SMTP_PASSWORD=your-app-password

SMTP_FROM=ROMI TRADERS <your-email@gmail.com>


# ==========================================
# CLOUDINARY
# ==========================================

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=


# ==========================================
# STRIPE
# ==========================================

STRIPE_PUBLIC_KEY=

STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=


# ==========================================
# PAYPAL
# ==========================================

PAYPAL_CLIENT_ID=

PAYPAL_CLIENT_SECRET=


